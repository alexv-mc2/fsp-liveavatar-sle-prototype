# FSP LiveAvatar SLE prototype — placeholder names only (never commit real values).
# Copy to .env.local for local development. Set the same keys in Vercel Project Settings
# for preview/production. See docs/VERCEL_HEYGEN_BRIDGE.md.

# --- Custom LLM public HTTPS base (required for HeyGen bridge) ---
# Stable production example: https://fsp-liveavatar-sle-prototype.vercel.app
# On Vercel, VERCEL_URL is injected automatically; FSP_PUBLIC_BASE_URL overrides it
# when you need a fixed production domain for HeyGen Custom LLM callbacks.
FSP_PUBLIC_BASE_URL=

# --- HeyGen / LiveAvatar server credentials (canonical FSP names) ---
HEYGEN_API_KEY=
HEYGEN_LIVEAVATAR_AVATAR_ID=
HEYGEN_LIVEAVATAR_VOICE_ID=

# --- ExpoWall read-only alias names (optional local reuse; not required on Vercel) ---
# If set locally, readHeyGenEnvSnapshot() accepts these as fallbacks for the HEYGEN_* keys above.
# LIVEAVATAR_API_KEY=
# LIVEAVATAR_AVATAR_ID=
# LIVEAVATAR_VOICE_ID=
# LIVEAVATAR_CONTEXT_ID=
# LIVEAVATAR_LLM_CONFIGURATION_ID=
# LIVEAVATAR_BASE_URL=https://api.liveavatar.com
# LIVEAVATAR_LANGUAGE=de
# LIVEAVATAR_INTERACTIVITY_TYPE=PUSH_TO_TALK
# LIVEAVATAR_SANDBOX=true
# LIVEAVATAR_MAX_SESSION_SECONDS=300
